{
  "rewrites": [
    { "source": "/waitlist",    "destination": "/waitlist/index.html" },
    { "source": "/waitlist/",   "destination": "/waitlist/index.html" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" }
      ]
    }
  ]
}
